# ─────────────────────────────────────────────
# ACPE Match — .gitignore
# Objectif : versionner le CODE + modèles/configs nécessaires,
#           EXCLUER les données personnelles (RGPD) et artefacts d'entraînement.
# ─────────────────────────────────────────────

# ── IDE / OS ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ──
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# ═════════════════════════════════════════════
# DONNÉES PERSONNELLES (RGPD) — STRICTEMENT EXCLUES
# ═════════════════════════════════════════════
# Base SQLite des candidats/offres (noms, prénoms, etc.)
*.db
acpe.db
backend/acpe.db

# Embeddings ChromaDB dérivés des profils (volumineux + données perso)
chroma_data/
backend/chroma_data/
chromadb/

# ═════════════════════════════════════════════
# ARTEFACTS D'ENTRAÎNEMENT (volumineux, régénérables)
# ═════════════════════════════════════════════
catboost_info/
captune_info/
cross_encoder_onnx/

# ═════════════════════════════════════════════
# LOGS / RAPPORTS DE TEST LOCAUX
# ═════════════════════════════════════════════
*.log
server.log
streamlit.log
logs/
test_report.txt
run_tests.ps1

# ── Secrets ──
*.key
*.pem
secrets/
.env

# ── Temporaires ──
tmp/
temp/
*.tmp
*.temp

# ═════════════════════════════════════════════
# NOTES
# ── Inclus intentionnellement (nécessaires au run) :
#    backend/catboost_ranker.cbm  (modèle, ~574 KB, non sensible)
#    backend/ranker_config.json   (feature names du ranker)
#    backend/faiss_offers.index   (index FAISS, ~10 MB)
#    matching_engine/.../graphs/*.json (graphes de connaissances)
#    matching_engine/.../skills/skills_enriched.json (référentiel compétences)
#    rapport_technique.md          (livrable hackathon)
# ═════════════════════════════════════════════
