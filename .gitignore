# ─────────────────────────────────────────────
# ACPE Match — .gitignore
# Versionne : CODE + modèles/configs nécessaires au run.
# Exclut : données perso (RGPD), artefacts, outils internes.
# ─────────────────────────────────────────────

# ── IDE / OS ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Outils internes ──
.opencode/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ──
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# ═════════════════════════════════════════════
# DONNÉES PERSONNELLES (RGPD) — STRICTEMENT EXCLUES
# ═════════════════════════════════════════════
# Base SQLite des candidats/offres (noms, prénoms, etc.)
*.db

# Embeddings ChromaDB dérivés des profils (volumineux + données perso)
chroma_data/
backend/chroma_data/
chromadb/

# ═════════════════════════════════════════════
# ARTEFACTS D'ENTRAÎNEMENT (volumineux, régénérables)
# ═════════════════════════════════════════════
catboost_info/
backend/catboost_info/
captune_info/
cross_encoder_onnx/

# Index FAISS stale (à reconstruire via build_faiss_index.py après le seed)
backend/faiss_offers.index
backend/faiss_offers_meta.json

# ═════════════════════════════════════════════
# LOGS / FICHIERS LOCAUX
# ═════════════════════════════════════════════
*.log
logs/
test_report.txt
run_tests.ps1
backend/server.err

# ── Secrets ──
*.key
*.pem
secrets/
.env

# ── Temporaires ──
tmp/
temp/
*.tmp
*.temp

# ═════════════════════════════════════════════
# NOTES
# ── Inclus intentionnellement (nécessaires au run) :
#    backend/catboost_ranker.cbm  (modèle, ~574 KB, non sensible)
#    backend/ranker_config.json   (feature names du ranker)
#    matching_engine/.../graphs/*.json (graphes de connaissances)
#    matching_engine/.../data/mappings/*.json (référentiels)
#    rapport_technique.md          (livrable hackathon)
# ═════════════════════════════════════════════
